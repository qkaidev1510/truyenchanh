# ============================================================
# Manga Platform — Environment Variables
# Copy this file to .env and fill in values before running.
# ============================================================

# --- Node ---
NODE_ENV=development

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=manga
POSTGRES_PASSWORD=manga_secret
POSTGRES_DB=manga_db
DATABASE_URL=postgresql://manga:manga_secret@localhost:5432/manga_db
# Read replica (can be same as primary in dev)
DATABASE_READ_URL=postgresql://manga:manga_secret@localhost:5432/manga_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_IMAGES=manga-images
MINIO_BUCKET_COVERS=manga-covers

# --- Meilisearch ---
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=masterKey123

# --- JWT ---
JWT_SECRET=change_me_in_production_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_in_production_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# --- API Signature ---
SIGNATURE_SECRET=change_me_in_production_signature_secret
# Set to true in dev to skip signature verification
DISABLE_SIGNATURE_CHECK=true
# Set to true in dev to skip rate limiting
DISABLE_RATE_LIMIT=true

# --- TOTP ---
TOTP_APP_NAME=TruyenChanh

# --- App URLs ---
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# --- Ports ---
API_PORT=4000
WEB_PORT=3000
